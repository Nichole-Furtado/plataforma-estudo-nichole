# Copie para .env e ajuste conforme necessário.
PORT=4000
NODE_ENV=development

# Caminho do Python para executar código no IDE (local).
PYTHON_PATH=python

# Origens permitidas (CORS). Separe múltiplas por vírgula.
# Local: http://localhost:3000
# Produção: adicione a URL da Vercel, ex: https://plataforma-nichole.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Liga/desliga a execução de código do IDE.
# Local: true. Em servidor público: false (por segurança).
ENABLE_CODE_EXECUTION=true

# Persistência dos dados.
# Vazio = salva em arquivos locais (ótimo para desenvolvimento).
# Para produção (Render), cole a connection string do MongoDB Atlas:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=nichole_study
